generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Race {
  P
  T
  Z
}

enum PlayerRole {
  MEMBER
  CAPTAIN
  VICE_CAPTAIN
}

enum TierBracket {
  TIER_1_2
  TIER_2_3
  TIER_3_4
  TIER_4_5
  TIER_2
  TIER_3
  TIER_4
  ACE
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model Season {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(false)
  teamCount Int      @default(4)
  rulesText String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams   Team[]
  matches Match[]
}

model Team {
  id        String @id @default(cuid())
  seasonId  String
  name      String
  shortName String?
  color     String @default("#3b82f6")
  sortOrder Int    @default(0)

  season        Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  players       Player[]
  homeMatches   Match[]  @relation("HomeTeam")
  awayMatches   Match[]  @relation("AwayTeam")
  wonSets       SetResult[] @relation("WinnerTeam")
  lostSets      SetResult[] @relation("LoserTeam")
  entrySlots    EntrySlot[]

  @@unique([seasonId, name])
  @@index([seasonId])
}

model Player {
  id            String     @id @default(cuid())
  teamId        String
  nickname      String
  race          Race
  tier          Int
  role          PlayerRole @default(MEMBER)
  isActive      Boolean    @default(true)
  discordUserId String?    @unique

  team       Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  wonSets    SetResult[] @relation("WinnerPlayer")
  lostSets   SetResult[] @relation("LoserPlayer")
  entrySlots EntrySlot[]

  @@unique([teamId, nickname])
  @@index([teamId])
}

model Match {
  id          String      @id @default(cuid())
  seasonId    String
  week        Int
  round       Int         @default(1)
  homeTeamId  String
  awayTeamId  String
  scheduledAt DateTime?
  bjName      String?
  vodUrl      String?
  status      MatchStatus @default(SCHEDULED)
  sixManEntryHome Boolean @default(false)
  sixManEntryAway Boolean @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  sets     Set[]
  entry    MatchEntry?

  @@index([seasonId])
  @@index([scheduledAt])
}

model Set {
  id          String      @id @default(cuid())
  matchId     String
  orderIndex  Int
  tierBracket TierBracket
  mapName     String?

  match      Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  result     SetResult?
  entrySlots EntrySlot[]

  @@unique([matchId, orderIndex])
  @@index([matchId])
}

model SetResult {
  id             String   @id @default(cuid())
  setId          String   @unique
  winnerTeamId   String
  loserTeamId    String
  winnerPlayerId String
  loserPlayerId  String?
  isForfeit      Boolean  @default(false)
  playedAt       DateTime @default(now())

  set          Set     @relation(fields: [setId], references: [id], onDelete: Cascade)
  winnerTeam   Team    @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  loserTeam    Team    @relation("LoserTeam", fields: [loserTeamId], references: [id])
  winnerPlayer Player  @relation("WinnerPlayer", fields: [winnerPlayerId], references: [id])
  loserPlayer  Player? @relation("LoserPlayer", fields: [loserPlayerId], references: [id])
}

model MatchEntry {
  id              String    @id @default(cuid())
  matchId         String    @unique
  homeConfirmedAt DateTime?
  awayConfirmedAt DateTime?
  publishedAt     DateTime?
  homeConfirmedBy String?
  awayConfirmedBy String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  match Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  slots EntrySlot[]
}

model EntrySlot {
  id       String @id @default(cuid())
  entryId  String
  teamId   String
  setId    String
  playerId String

  entry  MatchEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  team   Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  set    Set        @relation(fields: [setId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([entryId, teamId, setId])
  @@index([entryId])
  @@index([teamId])
  @@index([setId])
}
