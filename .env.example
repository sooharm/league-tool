# Neon Postgres — Connection pooler (Vercel/앱 런타임용)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/neondb?sslmode=require"

# Neon Postgres — Direct connection (prisma db push / migrate용)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# NextAuth — random string (e.g. openssl rand -base64 32)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# 로컬 개발(npm run dev) 시 Discord 로그인 없이 운영진 권한 사용 (기본 켜짐)
# DEV_STAFF_BYPASS="false"

# 로컬 개발(npm run dev) 시 승부예측 UI 미리보기 (19:00·DB 없이도 카드·배당 표시, 기본 켜짐)
# DEV_PREDICT_PREVIEW="false"

# Elo Board — 로컬(npm run dev)에서만 기본 노출. 배포에서 켜려면 ENABLE_ELO_BOARD=true
# ENABLE_ELO_BOARD="false"

# Season5 미니게임 — 로컬(npm run dev)에서만 기본 노출. 배포에서 켜려면 ENABLE_SEASON5=true
# ENABLE_SEASON5="false"

# 운영진 권한 — Discord 서버 역할 ID (개발자 모드 > 역할 우클릭 > ID 복사)
DISCORD_GUILD_ID=""
DISCORD_BOT_TOKEN=""
# 운영진 역할 ID (쉼표 구분) — 디스코드 역할로 운영진 지정 시
DISCORD_STAFF_ROLE_IDS=""

# 운영진 User ID (쉼표 구분) — 역할 없이 운영진만 지정 시 (관리자 권한 아님)
DISCORD_STAFF_USER_IDS=""

# 관리자 User ID (쉼표 구분) — 엔트리 양팀 등 전체 권한
DISCORD_ADMIN_USER_IDS=""